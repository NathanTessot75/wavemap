# Copiez ce fichier en « .env » et remplissez vos clés.
# NE COMMITEZ JAMAIS le .env réel.

# Stripe — tableau de bord > Développeurs > Clés API (commencez en MODE TEST)
# La clé secrète de test commence par sk_test_...
STRIPE_SECRET_KEY=sk_test_xxx

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx

# Webhook Stripe (optionnel) — fourni par « stripe listen » (voir SETUP.md)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optionnel : port et URL de base (par défaut http://localhost:5173)
PORT=5173
BASE_URL=http://localhost:5173
